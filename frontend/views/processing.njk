{% extends "layout.njk" %}

{% block pageTitle %}Processing your form — LAA CW1 Form Submission{% endblock %}

{% block content %}

  <div style="text-align: center; padding: 40px 0;">

    <h1 class="govuk-heading-l">Processing your form</h1>
    <p class="govuk-body-l">Our AI is reading your document — please wait</p>

    <!-- Animated document scanner -->
    <div style="display: inline-block; position: relative; width: 200px; height: 260px; margin: 30px auto;">
      <!-- Paper -->
      <svg viewBox="0 0 200 260" width="200" height="260" style="display: block;">
        <!-- Shadow -->
        <ellipse cx="100" cy="252" rx="80" ry="8" fill="#e0e0e0">
          <animate attributeName="rx" values="80;70;80" dur="2s" repeatCount="indefinite" />
        </ellipse>
        <!-- Page -->
        <rect x="30" y="10" width="140" height="190" rx="4" fill="white" stroke="#b1b4b6" stroke-width="2">
          <animate attributeName="y" values="10;6;10" dur="2s" repeatCount="indefinite" />
        </rect>
        <!-- Folded corner -->
        <path d="M 140 10 L 170 10 L 170 40 Z" fill="#f3f2f1" stroke="#b1b4b6" stroke-width="1.5">
          <animate attributeName="d" values="M 140 10 L 170 10 L 170 40 Z;M 140 6 L 170 6 L 170 36 Z;M 140 10 L 170 10 L 170 40 Z" dur="2s" repeatCount="indefinite" />
        </path>
        <!-- Text lines -->
        <g>
          <animate attributeName="transform" values="translate(0,0);translate(0,-4);translate(0,0)" dur="2s" repeatCount="indefinite" />
          <rect x="50" y="35" width="80" height="6" rx="3" fill="#505a5f" opacity="0.6" />
          <rect x="50" y="50" width="100" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="65" width="90" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="80" width="70" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="100" width="95" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="115" width="85" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="130" width="100" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="145" width="60" height="6" rx="3" fill="#b1b4b6" />
          <rect x="50" y="165" width="40" height="10" rx="2" fill="#505a5f" opacity="0.4" />
        </g>
        <!-- Scanner beam -->
        <rect x="30" y="20" width="140" height="3" rx="1.5" fill="#1d70b8" opacity="0.7">
          <animate attributeName="y" values="20;190;20" dur="2.5s" repeatCount="indefinite" />
          <animate attributeName="opacity" values="0.7;0.3;0.7" dur="2.5s" repeatCount="indefinite" />
        </rect>
        <!-- Sparkle effects when beam passes -->
        <circle cx="60" cy="50" r="3" fill="#1d70b8" opacity="0">
          <animate attributeName="opacity" values="0;1;0" dur="2.5s" repeatCount="indefinite" begin="0.3s" />
          <animate attributeName="r" values="2;5;2" dur="2.5s" repeatCount="indefinite" begin="0.3s" />
        </circle>
        <circle cx="140" cy="100" r="3" fill="#1d70b8" opacity="0">
          <animate attributeName="opacity" values="0;1;0" dur="2.5s" repeatCount="indefinite" begin="1s" />
          <animate attributeName="r" values="2;5;2" dur="2.5s" repeatCount="indefinite" begin="1s" />
        </circle>
        <circle cx="80" cy="150" r="3" fill="#1d70b8" opacity="0">
          <animate attributeName="opacity" values="0;1;0" dur="2.5s" repeatCount="indefinite" begin="1.7s" />
          <animate attributeName="r" values="2;5;2" dur="2.5s" repeatCount="indefinite" begin="1.7s" />
        </circle>
      </svg>
    </div>

    <!-- Progress bar -->
    <div style="max-width: 400px; margin: 0 auto;">
      <div style="background: #f3f2f1; border-radius: 4px; height: 8px; overflow: hidden;">
        <div id="progress-bar" style="background: #1d70b8; height: 100%; width: 0%; border-radius: 4px; transition: width 0.3s ease;"></div>
      </div>
      <p class="govuk-body govuk-!-margin-top-2" id="progress-text" style="color: #505a5f;">Starting extraction…</p>
    </div>

    <!-- Fun status messages -->
    <div class="govuk-!-margin-top-6">
      <p class="govuk-body" id="status-message" style="min-height: 1.5em; color: #505a5f; font-style: italic;">
        Warming up the OCR engine…
      </p>
    </div>

  </div>

  <script>
    (function () {
      var messages = [
        'Warming up the OCR engine…',
        'Scanning for handwriting…',
        'Deciphering solicitor penmanship… 🖊️',
        'Reading between the lines…',
        'Extracting client details…',
        'Cross-referencing form fields…',
        'Checking the date of birth…',
        'Looking up National Insurance number…',
        'Nearly there — validating data…',
        'Polishing the results…',
      ];

      var bar = document.getElementById('progress-bar');
      var text = document.getElementById('progress-text');
      var statusEl = document.getElementById('status-message');
      var msgIndex = 0;
      var processUrl = {{ ("'" + processUrl + "'") | safe if processUrl else "null" }};
      var fixedRedirectUrl = {{ ("'" + redirectUrl + "'") | safe if redirectUrl else "null" }};
      var backendDone = false;
      var backendRedirectUrl = null;
      var backendError = null;
      var minDisplayTime = 3000;
      var start = Date.now();

      // If we have a processUrl, call the backend via AJAX while the animation plays.
      if (processUrl) {
        fetch(processUrl, { method: 'POST' })
          .then(function (resp) { return resp.json(); })
          .then(function (data) {
            if (data.error) {
              backendError = data.error;
            } else {
              backendRedirectUrl = data.redirectUrl;
            }
            backendDone = true;
          })
          .catch(function () {
            backendError = 'There was a problem processing your image. Try again later.';
            backendDone = true;
          });
      } else {
        // Mock mode — simulate a fixed 10s wait then redirect
        backendDone = false;
      }

      function update() {
        var elapsed = Date.now() - start;

        // In mock mode (no processUrl), use a fixed 10s duration
        if (!processUrl) {
          var duration = 5000;
          var pct = Math.min((elapsed / duration) * 100, 100);
          bar.style.width = pct + '%';
          text.textContent = Math.round(pct) + '% complete';

          var newIndex = Math.min(Math.floor((elapsed / duration) * messages.length), messages.length - 1);
          if (newIndex !== msgIndex) {
            msgIndex = newIndex;
            statusEl.style.opacity = '0';
            setTimeout(function () {
              statusEl.textContent = messages[msgIndex];
              statusEl.style.opacity = '1';
            }, 200);
          }

          if (elapsed < duration) {
            requestAnimationFrame(update);
          } else {
            text.textContent = '100% — redirecting…';
            window.location.href = fixedRedirectUrl;
          }
          return;
        }

        // Real mode — animate progress while waiting for backend
        if (backendError) {
          bar.style.background = '#d4351c';
          bar.style.width = '100%';
          text.textContent = 'Error';
          statusEl.textContent = backendError;
          statusEl.style.fontStyle = 'normal';
          statusEl.style.color = '#d4351c';
          return;
        }

        if (backendDone && elapsed >= minDisplayTime) {
          bar.style.width = '100%';
          text.textContent = '100% — redirecting…';
          statusEl.textContent = 'Extraction complete!';
          window.location.href = backendRedirectUrl;
          return;
        }

        // Gradually fill progress bar — cap at 90% until backend finishes
        var maxPct = backendDone ? 100 : 90;
        var pct = Math.min((elapsed / 30000) * 90, maxPct);
        bar.style.width = pct + '%';
        text.textContent = Math.round(pct) + '% complete';

        // Cycle through messages based on elapsed time
        var newIndex = Math.min(Math.floor(elapsed / 3000), messages.length - 1);
        if (newIndex !== msgIndex) {
          msgIndex = newIndex;
          statusEl.style.opacity = '0';
          setTimeout(function () {
            statusEl.textContent = messages[msgIndex];
            statusEl.style.opacity = '1';
          }, 200);
        }

        requestAnimationFrame(update);
      }

      statusEl.style.transition = 'opacity 0.2s';
      requestAnimationFrame(update);
    })();
  </script>

{% endblock %}
