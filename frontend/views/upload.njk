{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/file-upload/macro.njk"   import govukFileUpload %}
{% from "govuk/components/input/macro.njk"         import govukInput %}
{% from "govuk/components/button/macro.njk"        import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/inset-text/macro.njk"    import govukInsetText %}

{% extends "layout.njk" %}

{% block pageTitle %}
  {% if errors and errors.length %}Error: {% endif %}Upload a CW1 form image — LAA CW1 Form Submission
{% endblock %}

{% block content %}

  {% if mockMode %}
    {{ govukNotificationBanner({
      text: "Mock mode is on. The backend API will not be called — a simulated response will be returned instead."
    }) }}
  {% endif %}

  {# Build error list for error summary #}
  {% if errors and errors.length %}
    {% set errorList = [] %}
    {% for error in errors %}
      {% set errorList = (errorList.push({ text: error.text, href: ("#" + error.field) if error.field }), errorList) %}
    {% endfor %}
    {{ govukErrorSummary({
      titleText: "There is a problem",
      errorList: errorList
    }) }}
  {% endif %}

  <h1 class="govuk-heading-l">Upload a CW1 form image</h1>
  <p class="govuk-body">
    Upload a scanned image of a completed CW1 Legal Help form. The service will
    read the form using OCR and extract the data for you to review and correct.
  </p>

  <div class="govuk-!-margin-bottom-6">
    <h2 class="govuk-heading-s govuk-!-margin-bottom-1">
      <span class="govuk-tag govuk-tag--blue govuk-!-margin-right-1">AI</span>
      How this service uses artificial intelligence
    </h2>
    {{ govukInsetText({
      html: '<p class="govuk-body">This service uses an AI-powered optical character recognition (OCR) model to extract information from your scanned form.</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>The AI reads text and checkbox data from the uploaded image</li>
        <li>Extracted data is shown to you for <strong>review and correction</strong> before anything is submitted</li>
        <li>No decisions are made by the AI — a caseworker always has the final say</li>
        <li>The uploaded document is processed in the UK and is not used to train AI models</li>
      </ul>'
    }) }}
  </div>

  <form method="POST" action="/" enctype="multipart/form-data" novalidate>

    {# Resolve per-field errors #}
    {% set imageError = null %}
    {% set emailError = null %}
    {% for error in errors %}
      {% if error.field === "image" %}{% set imageError = { text: error.text } %}{% endif %}
      {% if error.field === "email" %}{% set emailError = { text: error.text } %}{% endif %}
    {% endfor %}

    {{ govukFileUpload({
      id: "image",
      name: "image",
      javascript: true,
      label: {
        text: "Upload form image",
        classes: "govuk-label--m"
      },
      hint: {
        text: "Select a scan or photo of the completed paper form. Accepted formats: JPG, PNG, PDF, TIFF."
      },
      attributes: {
        accept: ".jpg,.jpeg,.png,.pdf,.tiff,.tif"
      },
      errorMessage: imageError
    }) }}

    {{ govukInput({
      id: "email",
      name: "email",
      type: "email",
      inputmode: "email",
      autocomplete: "email",
      spellcheck: false,
      classes: "govuk-input--width-20",
      label: {
        text: "Your email address",
        classes: "govuk-label--m"
      },
      hint: {
        text: "We'll use this to identify your submission."
      },
      value: values.email or "",
      errorMessage: emailError
    }) }}

    {{ govukButton({
      text: "Upload and extract data"
    }) }}

  </form>

{% endblock %}
